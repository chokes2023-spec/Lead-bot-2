# ─────────────────────────────────────────────
#  Web3 Lead Gen Bot — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (so the bot knows who to alert)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# Google Gemini API Key (from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail credentials for daily digest email
GMAIL_ADDRESS=larryojah11@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# GitHub Personal Access Token (optional but recommended)
# Get free token at github.com/settings/tokens — no special permissions needed
GITHUB_TOKEN=your_github_token_here

# Digest delivery email
DIGEST_EMAIL=larryojah11@gmail.com

# Daily digest time (24hr format, UTC)
DIGEST_HOUR=6
DIGEST_MINUTE=0
